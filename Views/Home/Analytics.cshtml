@model IEnumerable<StudyBuddy.Models.StudyDocument>

@* title and doc counter *@
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Study Analytics</h2>
        <div class="h4">
            Total Documents: <span class="badge bg-primary" id="totalDocsCounter">@Model.Count()</span>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-8">
            @* This empty column for spacing *@
        </div>
        @* create subject filter based on folders in study hub *@
        <div class="col-md-4">
            <label class="form-label text-muted small mb-1">Filter by Subject</label>
            <select id="analyticsFolderFilter" class="form-select shadow-sm" onchange="filterAnalyticsChart()">
                <option value="all">All Subjects</option>
                <option value="unfiled">Unfiled (General)</option>
                @if (ViewBag.Folders != null)
                {
                    @foreach (var folder in (List<FolderModel>)ViewBag.Folders)
                    {
                        <option value="@folder.Name">@folder.Name</option>
                    }
                }
            </select>
        </div>
    </div>

    @* pie chart *@
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-muted mb-4">Document Status Breakdown</h5>
                    <div style="height: 300px;">
                        <canvas id="statusPieChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        @* bar chart *@
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-muted mb-4">Files per Subject</h5>
                    <div style="height: 300px;">
                        <canvas id="subjectBarChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        @* line chart *@
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title text-muted mb-4">Upload Activity (Last 7 Days)</h5>
                    <div style="height: 400px;">
                        <canvas id="activityLineChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* time filter *@
<div class="card shadow-sm border-0 mt-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="card-title text-muted mb-0">Activity Time Range</h5>
            @* Toggle Button *@
            <button id="allTimeBtn" class="btn btn-sm btn-primary" onclick="toggleAllTime()">All Time</button>
        </div>

        <div id="sliderContainer" class="px-2 mt-3" style="opacity: 0.5; pointer-events: none;">
            <input type="range" class="form-range" min="7" max="180" value="30" id="timeSlider" oninput="updateChartTime(this.value)">

            <div class="position-relative small text-muted mt-1" style="height: 20px;">
                <span class="position-absolute" style="left: 0%; transform: translateX(0%);">1 Week</span>
                <span class="position-absolute" style="left: 13.3%; transform: translateX(-50%);">1 Month</span>
                <span class="position-absolute" style="left: 48%; transform: translateX(-50%);">3 Months</span>
                <span class="position-absolute" style="left: 100%; transform: translateX(-100%);">6 Months</span>
            </div>

            <div class="text-center mt-3">
                <span id="sliderValueLabel" class="badge bg-secondary">All Time</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Safely loads the C# data into a JavaScript variable
        const rawDocumentData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    </script>
    <script src="~/js/charts.js"></script>
}