@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">
    <div class="jumbotron text-center bg-light p-5 rounded">
        <h1 class="display-4">Study Assistant Portal</h1>
        <p class="lead">Simplifying the way students manage, review, and track their academic progress.</p>
        <hr class="my-4">
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <h3>Project Purpose</h3>
            <p>
                The Study Assistant is designed to provide a centralized platform for students to organize
                their learning materials. This prototype focuses on creating a seamless "Look and Feel"
                for managing document storage and review cycles, ensuring that no study material
                is left unreviewed[cite: 3, 7].
            </p>
        </div>

        <div class="col-md-6">
            <h3>Key Features</h3>
            <ul class="list-group">
                <li class="list-group-item"><strong>Document Repository:</strong> Securely store and categorize your study files.</li>
                <li class="list-group-item"><strong>Review Tracking:</strong> Mark documents as "Reviewed" to monitor your learning milestones.</li>
                <li class="list-group-item"><strong>Personalized Notes:</strong> Add and update custom study notes for every record.</li>
                <li class="list-group-item"><strong>AI Assistant:</strong> Interact with an integrated Botpress chatbot for instant help[cite: 28, 29].</li>
                <li class="list-group-item"><strong>Visual Analytics:</strong> View your progress through interactive data charts[cite: 20].</li>
            </ul>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12 text-center">
            <p>Use the navigation menu above to explore your <strong>Data Visualizations</strong> or manage your <strong>Records</strong>.</p>
        </div>
    </div>
</div>