@model IEnumerable<StudyBuddy.Models.StudyDocument>

@{
    // grabs the name set in the Controller
    var displayFolder = ViewData["FolderName"]?.ToString() ?? "Subject Folder";
    ViewData["Title"] = displayFolder;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Hub">Hub</a></li>
            <li class="breadcrumb-item active" aria-current="page">@ViewData["FolderName"]</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-folder-open text-warning me-2"></i> @ViewData["FolderName"]</h2>

        <button type="button" class="btn btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#uploadModal"
                data-folder-name="@displayFolder">
            <i class="fas fa-plus"></i> Upload to this Folder
        </button>
    </div>

    <partial name="_DocumentTable" model="Model" />
</div>

@section Scripts {
    <script src="~/js/studyhub.js"></script>
}