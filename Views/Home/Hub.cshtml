@model IEnumerable<StudyBuddy.Models.StudyDocument>
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Study Hub</h2>
            <div class="d-flex gap-2">
                @* new folder button *@
                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#newFolderModal">
                    <i class="fas fa-folder-plus"></i> New Folder
                </button>
                @* upload button *@
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                    <i class="fas fa-plus"></i> New Upload
                </button>
            </div>
    </div>

    <h4 class="text-muted"><i class="fas fa-folder-open"></i> Subject Folders</h4>
    <div class="row mb-5">
        @if (ViewBag.Folders != null)
        {
            @foreach (var folder in (List<FolderModel>)ViewBag.Folders)
            {
                <div class="col-md-4 mb-4">
                    @* Pass folder.Name (string) instead of folder (object) *@
                    <partial name="_FolderCard" model="folder.Name" />
                </div>
            }
        }
    </div>

    <h4 class="text-muted"><i class="fas fa-file-alt"></i> Unfiled Documents</h4>
    <partial name="_DocumentTable" />

   

@section Scripts {
    <script src="~/js/studyhub.js"></script>
}