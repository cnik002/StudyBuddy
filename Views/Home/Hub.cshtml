@model IEnumerable<StudyBuddy.Models.StudyDocument>
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Study Hub</h2>
            <div class="d-flex gap-2">
                @* new folder button *@
                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#newFolderModal">
                    <i class="fas fa-folder-plus"></i> New Folder
                </button>
                @* upload button *@
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                    <i class="fas fa-plus"></i> New Upload
                </button>
            </div>

        <td>
            <a asp-action="ViewLibrary" class="text-primary me-2"><i class="fas fa-eye"></i></a>
            <a href="#" class="text-warning me-2" data-bs-toggle="modal" data-bs-target="#editModal"><i class="fas fa-pencil-alt"></i></a>
            <a asp-action="Delete" class="text-danger"><i class="fas fa-trash"></i></a>
        </td>
    </div>

    <h4 class="text-muted"><i class="fas fa-folder-open"></i> Subject Folders</h4>
    <div class="row mb-5">
        <div class="col-md-3 mb-3">
            <div class="card h-100 shadow-sm border-0 bg-light">
                <div class="card-body text-center">
                    <i class="fas fa-folder fa-3x text-warning mb-2"></i>
                    <h5 class="card-title">ISM 6225</h5>
                    <p class="small text-muted">12 Documents</p>
                    <a asp-action="FolderView" asp-route-id="ISM 6225" class="btn btn-sm btn-outline-secondary">Open</a>
                </div>
            </div>
        </div>
    </div>

    @* <h4 class="text-muted"><i class="fas fa-file-alt"></i> Unfiled Documents</h4>
    <div class="table-responsive bg-white shadow-sm rounded p-3">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>File Name</th>
                    <th>Date Added</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Assignment_Draft_v1.docx</td>
                    <td>Apr 8, 2026</td>
                    <td><span class="badge bg-info">Draft</span></td>
                    <td>
                        <a asp-action="ViewLibrary" class="text-primary me-2"><i class="fas fa-eye"></i></a>
                        <a asp-action="Edit" class="text-warning me-2"><i class="fas fa-edit"></i></a>
                        <a asp-action="Delete" class="text-danger"><i class="fas fa-trash"></i></a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div> *@

    <h4 class="text-muted"><i class="fas fa-file-alt"></i> Unfiled Documents</h4>
    <partial name="_DocumentTable" />

    @* new file upload popup *@
    <div class="modal fade" id="uploadModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Upload New Study Material</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form>
                        <div class="mb-3">
                            <label class="form-label">File Select</label>
                            <input type="file" class="form-control">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Categorize in Folder</label>
                            <select class="form-select" id="folderDropdown" onchange="toggleNewFolderInput()">
                                <option value="unfiled" selected>Unfiled</option>
                                <option value="1">ISM 6225</option>
                                <option value="2">Data Analytics</option>
                                <option value="NEW">-- Create New Folder --</option>
                            </select>
                        </div>

                        <div id="newFolderContainer" class="mt-3" style="display: none;">
                            <label class="form-label text-primary fw-bold">New Folder Name</label>
                            <input type="text" class="form-control border-primary" id="newFolderText" placeholder="e.g. ISM 6400">
                        </div>

                        <div class="row mb-3">
                            <div class="col">
                                <label class="form-label">Set Status</label>
                                <select class="form-select">
                                    <option value="1">Draft</option>
                                    <option value="2">Reviewed</option>
                                </select>
                            </div>
                            <div class="col">
                                <label class="form-label">File Type</label>
                                <select class="form-select">
                                    <option value="1">PDF</option>
                                    <option value="2">DOCX</option>
                                    <option value="3">Image</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Comments/Notes</label>
                            <textarea class="form-control" rows="3" placeholder="Add initial study notes..."></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="showSuccess()">Save & Upload</a>
                </div>
            </div>
        </div>
    </div>

    @* new folder popup *@
    <div class="modal fade" id="newFolderModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">New Subject Folder</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="text" class="form-control" placeholder="Folder Name (e.g. ISM 6000)">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary w-100">Create Folder</button>
                </div>
            </div>
        </div>
    </div>

    @* upload success static popup*@
    <div class="modal fade" id="successModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center pb-5">
                    <i class="fas fa-check-circle fa-5x text-success mb-3"></i>
                    <h3>Upload Successful!</h3>
                    <p class="text-muted">Your document has been categorized and added to the Study Hub.</p>
                    <button type="button" class="btn btn-success px-4" data-bs-dismiss="modal">Great!</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/studyhub.js"></script>
}