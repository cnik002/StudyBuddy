@model string
@{
    var cardId = "folder-" + Model.Replace(" ", "");
}

<div class="col-md-4 mb-4">
    <div id="@cardId" class="card h-100 border-primary shadow-sm" style="background-color: rgba(13, 110, 253, 0.05);">

        <div class="dropdown position-absolute" style="top: 10px; right: 10px;">
            <button class="btn btn-link text-muted p-0" type="button" data-bs-toggle="dropdown">
                <i class="fas fa-ellipsis-v"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-3" style="min-width: 200px;">
                <li><a class="dropdown-item p-0 mb-2" href="#" onclick="openRenameModal('@Model')"><i class="fas fa-edit me-2 text-warning"></i> Rename</a></li>

                <li class="small text-muted mb-2">Change Color</li>
                <li>
                    <div class="d-grid" style="grid-template-columns: repeat(3, 1fr); gap: 10px; padding: 5px;">
                        <div class="rounded-circle bg-danger" style="width:24px; height:24px; cursor:pointer; border: 1px solid #ddd;" onclick="changeFolderColor('@cardId', 'danger')" title="Red"></div>
                        <div class="rounded-circle" style="width:24px; height:24px; cursor:pointer; background-color: #fd7e14; border: 1px solid #ddd;" onclick="changeFolderColor('@cardId', 'orange')" title="Orange"></div>
                        <div class="rounded-circle bg-warning" style="width:24px; height:24px; cursor:pointer; border: 1px solid #ddd;" onclick="changeFolderColor('@cardId', 'warning')" title="Yellow"></div>
                        
                        <div class="rounded-circle" style="width:24px; height:24px; cursor:pointer; background-color: #6f42c1; border: 1px solid #ddd;" onclick="changeFolderColor('@cardId', 'purple')" title="Purple"></div>
                        <div class="rounded-circle" style="width:24px; height:24px; cursor:pointer; background-color: #d63384; border: 1px solid #ddd;" onclick="changeFolderColor('@cardId', 'pink')" title="Pink"></div>
                        <div class="rounded-circle bg-success" style="width:24px; height:24px; cursor:pointer; border: 1px solid #ddd;" onclick="changeFolderColor('@cardId', 'success')" title="Green"></div>
                        
                        <div class="rounded-circle bg-primary" style="width:24px; height:24px; cursor:pointer; border: 1px solid #ddd;" onclick="changeFolderColor('@cardId', 'primary')" title="Blue"></div>
                        <div class="rounded-circle bg-info" style="width:24px; height:24px; cursor:pointer; border: 1px solid #ddd;" onclick="changeFolderColor('@cardId', 'info')" title="Cyan"></div>
                        <div class="rounded-circle bg-secondary" style="width:24px; height:24px; cursor:pointer; border: 1px solid #ddd;" onclick="changeFolderColor('@cardId', 'secondary')" title="Grey"></div>
                    </div>
                </li>

                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger p-0" href="#" onclick="confirmDelete('@Model')"><i class="fas fa-trash-alt me-2"></i> Delete Folder</a></li>
            </ul>
        </div>

        <div class="card-body text-center pt-4">
            <div class="display-4 text-primary mb-2">
                <i class="fas fa-folder"></i>
            </div>
            <h5 class="card-title">@Model</h5>
            <p class="small text-muted">2 Documents</p>
            <a asp-action="FolderView" asp-route-id="@Model" class="btn btn-sm btn-outline-secondary">Open</a>
        </div>
    </div>
</div>