<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudyBuddy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StudyBuddy.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">StudyBuddy</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                @* navigation buttons *@
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Hub">Study Hub</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Analytics">Analytics</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="About">About Us</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - StudyBuddy - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/studyhub.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)

    @* upload new material popup *@
    <div class="modal fade" id="uploadModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white border-0">
                    <h5 class="modal-title">Upload Study Material</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="uploadForm">
                        <div class="mb-3">
                            <label class="form-label">File Name</label>
                            <input type="text" class="form-control" id="uploadFileName" placeholder="e.g. SQL_Lecture_Notes">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Subject Folder</label>
                            <select class="form-select" id="folderDropdown" onchange="toggleNewFolderInput()">
                                <option value="unfiled" selected>Unfiled (General)</option>
                                <option value="ISM 6225">ISM 6225</option>
                                <option value="ISM 6419">ISM 6419</option>
                                <option value="FIN 6406">FIN 6406</option>
                                <option value="MAR 6815">MAR 6815</option>
                                <option value="QMB 6305">QMB 6305</option>
                                <option value="NEW" class="fw-bold text-primary">+ Create New Subject</option>
                            </select>
                        </div>

                        <div id="newFolderContainer" style="display: none;" class="mt-2">
                            <label class="form-label small text-muted">New Subject Name</label>
                            <input type="text" class="form-control" placeholder="e.g. ACG 2021">
                        </div>

                        <div class="mb-3 mt-3">
                            <label class="form-label">Initial Status</label>
                            <select class="form-select" id="uploadStatus">
                                <option value="Draft">Draft</option>
                                <option value="In Progress">In Progress</option>
                                <option value="Reviewed">Reviewed</option>
                            </select>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="showSuccess()">Save & Upload</button>
                </div>
            </div>
        </div>
    </div>

    @* edit popup *@
    <div class="modal fade" id="editDocumentModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Edit Document Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Document Name</label>
                        <div class="input-group">
                            <input type="text" id="editDocNameInput" class="form-control">
                            <span class="input-group-text" id="fileExtensionLabel">.pdf</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Subject</label>
                        <select class="form-select" id="editDocSubject" onchange="toggleNewFolderInput('editDocSubject', 'editNewSubjectContainer')">
                            <option value="Unfiled">Unfiled</option>
                            <option value="ISM 6225">ISM 6225</option>
                            <option value="ISM 6419">ISM 6419</option>
                            <option value="FIN 6406">FIN 6406</option>
                            <option value="MAR 6815">MAR 6815</option>
                            <option value="QMB 6305">QMB 6305</option>
                            <option value="NEW" class="fw-bold text-primary">+ Create New Subject</option>
                        </select>
                    </div>

                    <div id="editNewSubjectContainer" style="display: none;" class="mt-2">
                        <label class="form-label small text-muted">New Subject Name</label>
                        <input type="text" class="form-control" placeholder="e.g. ACG 2021">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select class="form-select" id="editDocStatus">
                            <option value="Draft">Draft</option>
                            <option value="In Progress">In Progress</option>
                            <option value="Reviewed">Reviewed</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="executeDocEdit()">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    @* rename popup *@
    <div class="modal fade" id="renameFolderModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Rename Folder</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">New Name</label>
                        <input type="text" id="folderRenameInput" class="form-control" autofocus>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="executeRename()">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    @* delete popup *@
    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-danger"><i class="fas fa-exclamation-triangle"></i> Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center py-4">
                    <p class="fs-5">Are you sure you want to delete <strong id="deleteTargetName"></strong>?</p>
                    <p class="text-muted small">This action cannot be undone.</p>
                </div>
                <div class="modal-footer border-0 justify-content-center">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" onclick="executeDelete()">Delete</button>
                </div>
            </div>
        </div>
    </div>

    @* success message popup *@
    <div class="modal fade" id="successModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content text-center p-4">
                <div class="modal-body">
                    <div class="mb-3">
                        <i id="successIcon" class="fas fa-check-circle fa-4x text-success"></i>
                    </div>
                    <h4 id="successTitle">Success!</h4>
                    <p id="successMessage" class="text-muted"></p>
                    <button type="button" class="btn btn-success px-4" data-bs-dismiss="modal">Great!</button>
                </div>
            </div>
        </div>
    </div>

    @* new folder popup *@
    <div class="modal fade" id="newFolderModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white border-0">
                    <h5 class="modal-title">Create New Folder</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Folder / Subject Name</label>
                        <input type="text" class="form-control" placeholder="e.g. ACG 2021">
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success" onclick="showStatusModal('Folder Created', 'Your new subject folder is ready.', 'fa-folder-plus', 'text-success')">Create Folder</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.botpress.cloud/webchat/v3.6/inject.js"></script>
    <script src="https://files.bpcontent.cloud/2026/04/10/00/20260410003044-6I68RIPW.js" defer></script>

</body>
</html>